sequenceDiagram
    participant U as User
    participant M as main.c
    participant S as sql.c
    participant T as table.c
    participant B as B+ Tree

    U->>M: SELECT * FROM users<br/>WHERE id >= 10;
    M->>S: sql_execute(<br/>table, input)
    S->>S: parse query<br/>and WHERE clause
    S->>T: table_find_by_id_<br/>condition(<br/>table, >=, 10)
    T->>B: table_find_id_leaf(<br/>10)
    B-->>T: return start leaf
    T->>B: scan leaf.next<br/>chain
    B-->>T: matching<br/>Record*
    T-->>S: matching rows<br/>+ row_count
    S-->>M: SQLResult<br/>{OK, SELECT_ROWS}

    alt row_count > 0
        M->>T: table_print_records(<br/>records,<br/>row_count)
        T-->>U: render matching rows<br/>id, name, age
    else row_count == 0
        M-->>U: Not found
    end

    M->>S: sql_result_destroy(<br/>&result)
