        {
          "name": "05 Mixed 80/20 burst",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const dummyBody = pm.response.json();",
                  "const readCount = Number(pm.collectionVariables.get('mixedReadCount') || '8');",
                  "const writeCount = Number(pm.collectionVariables.get('mixedWriteCount') || '2');",
                  "const seedId = Number(pm.collectionVariables.get('burstSeedId') || '0');",
                  "",
                  "pm.test('mixed burst trigger request returns 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "  pm.expect(dummyBody.status).to.eql('not_found');",
                  "});",
                  "",
                  "pm.test('mixed 80/20 burst completes with successful reads and writes', function (done) {",
                  "  const baseUrl = pm.collectionVariables.get('baseUrl');",
                  "  const total = readCount + writeCount;",
                  "  let pending = total;",
                  "  const failures = [];",
                  "  const writeIds = [];",
                  "",
                  "  pm.expect(seedId).to.be.above(0);",
                  "  pm.expect(readCount).to.be.above(0);",
                  "  pm.expect(writeCount).to.be.above(0);",
                  "",
                  "  function finalize() {",
                  "    try {",
                  "      pm.expect(writeIds.length).to.eql(writeCount);",
                  "      pm.expect(new Set(writeIds).size).to.eql(writeCount);",
                  "      pm.expect(failures, failures.join('\\n')).to.be.empty;",
                  "      pm.collectionVariables.set('mixedBurstInsertedIds', JSON.stringify(writeIds));",
                  "      done();",
                  "    } catch (error) {",
                  "      done(error);",
                  "    }",
                  "  }",
                  "",
                  "  function finishOne() {",
                  "    pending -= 1;",
                  "    if (pending === 0) {",
                  "      finalize();",
                  "    }",
                  "  }",
                  "",
                  "  function sendRead(index) {",
                  "    pm.sendRequest({",
                  "      url: baseUrl + '/query',",
                  "      method: 'POST',",
                  "      header: { 'Content-Type': 'application/json' },",
                  "      body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({ query: 'SELECT * FROM users WHERE id = ' + seedId + ';' })",
                  "      }",
                  "    }, function (err, res) {",
                  "      if (err) {",
                  "        failures.push('mixed read ' + index + ' network error: ' + err);",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      let body;",
                  "      try {",
                  "        body = res.json();",
                  "      } catch (parseError) {",
                  "        failures.push('mixed read ' + index + ' returned non-JSON body');",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      if (res.code !== 200) {",
                  "        failures.push('mixed read ' + index + ' returned status ' + res.code);",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      try {",
                  "        pm.expect(body.ok, 'mixed read ' + index + ' ok').to.eql(true);",
                  "        pm.expect(body.action, 'mixed read ' + index + ' action').to.eql('select');",
                  "        pm.expect(body.usedIndex, 'mixed read ' + index + ' usedIndex').to.eql(true);",
                  "        pm.expect(body.rowCount, 'mixed read ' + index + ' rowCount').to.eql(1);",
                  "        pm.expect(body.rows[0].id, 'mixed read ' + index + ' row id').to.eql(seedId);",
                  "      } catch (assertError) {",
                  "        failures.push(assertError.message);",
                  "      }",
                  "",
                  "      finishOne();",
                  "    });",
                  "  }",
                  "",
                  "  function sendWrite(index) {",
                  "    const name = 'Mixed Writer ' + index;",
                  "    const age = 30 + index;",
                  "    pm.sendRequest({",
                  "      url: baseUrl + '/query',",
                  "      method: 'POST',",
                  "      header: { 'Content-Type': 'application/json' },",
                  "      body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({ query: \"INSERT INTO users VALUES ('\" + name + \"', \" + age + \");\" })",
                  "      }",
                  "    }, function (err, res) {",
                  "      if (err) {",
                  "        failures.push('mixed write ' + index + ' network error: ' + err);",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      let body;",
                  "      try {",
                  "        body = res.json();",
                  "      } catch (parseError) {",
                  "        failures.push('mixed write ' + index + ' returned non-JSON body');",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      if (res.code !== 200) {",
                  "        failures.push('mixed write ' + index + ' returned status ' + res.code);",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      try {",
                  "        pm.expect(body.ok, 'mixed write ' + index + ' ok').to.eql(true);",
                  "        pm.expect(body.action, 'mixed write ' + index + ' action').to.eql('insert');",
                  "        pm.expect(body.usedIndex, 'mixed write ' + index + ' usedIndex').to.eql(false);",
                  "        pm.expect(body.insertedId, 'mixed write ' + index + ' insertedId').to.be.a('number');",
                  "        writeIds.push(body.insertedId);",
                  "      } catch (assertError) {",
                  "        failures.push(assertError.message);",
                  "      }",
                  "",
                  "      finishOne();",
                  "    });",
                  "  }",
                  "",
                  "  for (let index = 0; index < readCount; index += 1) {",
                  "    sendRead(index);",
                  "  }",
                  "",
                  "  for (let index = 0; index < writeCount; index += 1) {",
                  "    sendWrite(index);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/__postman__/mixed-burst-trigger"
          }
