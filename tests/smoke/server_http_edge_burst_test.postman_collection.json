        {
          "name": "08 Final edge metrics",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const baseline = JSON.parse(pm.collectionVariables.get('edgeBaselineMetrics') || '{}');",
                  "const metrics = body.metrics || {};",
                  "",
                  "function delta(key) {",
                  "  return Number(metrics[key] || 0) - Number(baseline[key] || 0);",
                  "}",
                  "",
                  "pm.test('final edge metrics returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('routing and malformed_http stay out of DB metrics while EXIT and QUIT are counted', function () {",
                  "  pm.expect(body.ok).to.eql(true);",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(delta('totalRequests')).to.eql(3);",
                  "  pm.expect(delta('totalHealthRequests')).to.eql(0);",
                  "  pm.expect(delta('totalMetricsRequests')).to.eql(1);",
                  "  pm.expect(delta('totalQueryRequests')).to.eql(2);",
                  "  pm.expect(delta('totalSelectRequests')).to.eql(0);",
                  "  pm.expect(delta('totalInsertRequests')).to.eql(0);",
                  "  pm.expect(delta('totalErrors')).to.eql(2);",
                  "  pm.expect(delta('totalSyntaxErrors')).to.eql(0);",
                  "  pm.expect(delta('totalQueryErrors')).to.eql(2);",
                  "  pm.expect(delta('totalInternalErrors')).to.eql(0);",
                  "  pm.expect(delta('totalNotFoundResults')).to.eql(0);",
                  "  pm.expect(delta('totalQueueFull')).to.eql(0);",
                  "  pm.expect(delta('totalLockTimeouts')).to.eql(0);",
                  "  pm.expect(Number(metrics.activeQueryRequests)).to.eql(0);",
                  "});"
                ]
              }
