      "name": "02 Burst Tests",
      "item": [
        {
          "name": "00 Seed burst dataset",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "",
                  "pm.test('burst seed insert returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('burst seed insert captures a valid id', function () {",
                  "  pm.expect(body.ok).to.eql(true);",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(body.action).to.eql('insert');",
                  "  pm.expect(body.insertedId).to.be.a('number');",
                  "  pm.expect(body.insertedId).to.be.above(0);",
                  "});",
                  "",
                  "pm.collectionVariables.set('burstSeedId', String(body.insertedId));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"INSERT INTO users VALUES ('Burst Seed', 11);\"\n}"
            },
            "url": "{{baseUrl}}/query"
          }
        },
        {
          "name": "01 Capture read-only burst baseline",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "",
                  "pm.test('read-only burst baseline returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.collectionVariables.set('readBurstBaselineMetrics', JSON.stringify(body.metrics || {}));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/metrics"
          }
        },
        {
          "name": "02 Read-only burst",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const dummyBody = pm.response.json();",
                  "const total = Number(pm.collectionVariables.get('readBurstCount') || '12');",
                  "const seedId = Number(pm.collectionVariables.get('burstSeedId') || '0');",
                  "",
                  "pm.test('read-only burst trigger request returns 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "  pm.expect(dummyBody.status).to.eql('not_found');",
                  "});",
                  "",
                  "pm.test('read-only burst completes with indexed read success', function (done) {",
                  "  const baseUrl = pm.collectionVariables.get('baseUrl');",
                  "  let pending = total;",
                  "  const failures = [];",
                  "  const responseCodes = [];",
                  "",
                  "  pm.expect(seedId).to.be.above(0);",
                  "  pm.expect(total).to.be.above(0);",
                  "",
                  "  function finalize() {",
                  "    try {",
                  "      pm.expect(responseCodes.length).to.eql(total);",
                  "      pm.expect(failures, failures.join('\\n')).to.be.empty;",
                  "      done();",
                  "    } catch (error) {",
                  "      done(error);",
                  "    }",
                  "  }",
                  "",
                  "  function finishOne() {",
                  "    pending -= 1;",
                  "    if (pending === 0) {",
                  "      finalize();",
                  "    }",
                  "  }",
                  "",
                  "  for (let index = 0; index < total; index += 1) {",
                  "    pm.sendRequest({",
                  "      url: baseUrl + '/query',",
                  "      method: 'POST',",
                  "      header: { 'Content-Type': 'application/json' },",
                  "      body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({ query: 'SELECT * FROM users WHERE id = ' + seedId + ';' })",
                  "      }",
                  "    }, function (err, res) {",
                  "      responseCodes.push(err ? 0 : res.code);",
                  "",
                  "      if (err) {",
                  "        failures.push('read ' + index + ' network error: ' + err);",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      let body;",
                  "      try {",
                  "        body = res.json();",
                  "      } catch (parseError) {",
                  "        failures.push('read ' + index + ' returned non-JSON body');",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      if (res.code !== 200) {",
                  "        failures.push('read ' + index + ' returned status ' + res.code);",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      try {",
                  "        pm.expect(body.ok, 'read ' + index + ' ok').to.eql(true);",
                  "        pm.expect(body.status, 'read ' + index + ' status').to.eql('ok');",
                  "        pm.expect(body.action, 'read ' + index + ' action').to.eql('select');",
                  "        pm.expect(body.usedIndex, 'read ' + index + ' usedIndex').to.eql(true);",
                  "        pm.expect(body.rowCount, 'read ' + index + ' rowCount').to.eql(1);",
                  "        pm.expect(body.rows, 'read ' + index + ' rows').to.be.an('array').with.lengthOf(1);",
                  "        pm.expect(body.rows[0].id, 'read ' + index + ' row id').to.eql(seedId);",
                  "      } catch (assertError) {",
                  "        failures.push(assertError.message);",
                  "      }",
                  "",
                  "      finishOne();",
                  "    });",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/__postman__/read-burst-trigger"
          }
        },
        {
          "name": "03 Final read-only burst metrics",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const baseline = JSON.parse(pm.collectionVariables.get('readBurstBaselineMetrics') || '{}');",
                  "const metrics = body.metrics || {};",
                  "const total = Number(pm.collectionVariables.get('readBurstCount') || '12');",
                  "",
                  "function delta(key) {",
                  "  return Number(metrics[key] || 0) - Number(baseline[key] || 0);",
                  "}",
                  "",
                  "pm.test('read-only burst metrics returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('read-only burst metrics match select-only fan-out', function () {",
                  "  pm.expect(delta('totalRequests')).to.eql(total + 1);",
                  "  pm.expect(delta('totalHealthRequests')).to.eql(0);",
                  "  pm.expect(delta('totalMetricsRequests')).to.eql(1);",
                  "  pm.expect(delta('totalQueryRequests')).to.eql(total);",
                  "  pm.expect(delta('totalSelectRequests')).to.eql(total);",
                  "  pm.expect(delta('totalInsertRequests')).to.eql(0);",
                  "  pm.expect(delta('totalErrors')).to.eql(0);",
                  "  pm.expect(delta('totalSyntaxErrors')).to.eql(0);",
                  "  pm.expect(delta('totalQueryErrors')).to.eql(0);",
                  "  pm.expect(delta('totalInternalErrors')).to.eql(0);",
                  "  pm.expect(delta('totalNotFoundResults')).to.eql(0);",
                  "  pm.expect(delta('totalQueueFull')).to.eql(0);",
                  "  pm.expect(delta('totalLockTimeouts')).to.eql(0);",
                  "  pm.expect(Number(metrics.activeQueryRequests)).to.eql(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/metrics"
          }
        },
        {
          "name": "04 Capture mixed 80/20 baseline",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
