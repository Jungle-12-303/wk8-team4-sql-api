          "name": "08 Write-heavy burst",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const dummyBody = pm.response.json();",
                  "const total = Number(pm.collectionVariables.get('writeBurstCount') || '10');",
                  "",
                  "pm.test('write-heavy burst trigger request returns 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "  pm.expect(dummyBody.status).to.eql('not_found');",
                  "});",
                  "",
                  "pm.test('write-heavy burst completes with unique inserted ids', function (done) {",
                  "  const baseUrl = pm.collectionVariables.get('baseUrl');",
                  "  let pending = total;",
                  "  const failures = [];",
                  "  const insertedIds = [];",
                  "",
                  "  pm.expect(total).to.be.above(0);",
                  "",
                  "  function finalize() {",
                  "    try {",
                  "      pm.expect(insertedIds.length).to.eql(total);",
                  "      pm.expect(new Set(insertedIds).size).to.eql(total);",
                  "      pm.expect(failures, failures.join('\\n')).to.be.empty;",
                  "      pm.collectionVariables.set('writeBurstInsertedIds', JSON.stringify(insertedIds));",
                  "      done();",
                  "    } catch (error) {",
                  "      done(error);",
                  "    }",
                  "  }",
                  "",
                  "  function finishOne() {",
                  "    pending -= 1;",
                  "    if (pending === 0) {",
                  "      finalize();",
                  "    }",
                  "  }",
                  "",
                  "  for (let index = 0; index < total; index += 1) {",
                  "    const name = 'Write Burst ' + index;",
                  "    const age = 40 + index;",
                  "    pm.sendRequest({",
                  "      url: baseUrl + '/query',",
