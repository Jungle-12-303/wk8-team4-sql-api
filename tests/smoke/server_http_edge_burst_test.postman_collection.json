                  "        raw: JSON.stringify({ query: \"INSERT INTO users VALUES ('\" + name + \"', \" + age + \");\" })",
                  "      }",
                  "    }, function (err, res) {",
                  "      if (err) {",
                  "        failures.push('write burst ' + index + ' network error: ' + err);",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      let body;",
                  "      try {",
                  "        body = res.json();",
                  "      } catch (parseError) {",
                  "        failures.push('write burst ' + index + ' returned non-JSON body');",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      if (res.code !== 200) {",
                  "        failures.push('write burst ' + index + ' returned status ' + res.code);",
                  "        finishOne();",
                  "        return;",
                  "      }",
                  "",
                  "      try {",
                  "        pm.expect(body.ok, 'write burst ' + index + ' ok').to.eql(true);",
                  "        pm.expect(body.action, 'write burst ' + index + ' action').to.eql('insert');",
                  "        pm.expect(body.usedIndex, 'write burst ' + index + ' usedIndex').to.eql(false);",
                  "        pm.expect(body.insertedId, 'write burst ' + index + ' insertedId').to.be.a('number');",
                  "        insertedIds.push(body.insertedId);",
                  "      } catch (assertError) {",
                  "        failures.push(assertError.message);",
                  "      }",
                  "",
                  "      finishOne();",
                  "    });",
                  "  }",
                  "});"
                ]
              }
            }
          ],
